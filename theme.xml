<?xml version="1.0" encoding="UTF-8"?>
<theme defaultView="gamecarousel">
   <formatVersion>4</formatVersion>
   <include>./config.xml</include>
   <include>./coinops-wheel.xml</include>
   <include>./$system/custom.xml</include>
   <!-- Per-system long description (CoinOPS). Included at top level so $system resolves.
        Each file scopes itself with ifSubset="systemview:CoinOPS", so it only shows in that view. -->
   <include>./$system/sysdesc.xml</include>
   <include subset="music" name="Mute" displayName="${silence}">./nosounds.xml</include>
   <include subset="music" name="On" displayName="${sysmusic}">./sounds.xml</include>
   <include subset="music" name="Off" displayName="${nomusic}"/>
   <include subset="MainBGColor" name="Default" displayName="${default}"/>
   <include subset="MainBGColor" name="Green" displayName="${huegreen}">./colorsets/green.xml</include>
   <include subset="MainBGColor" name="Red" displayName="${huered}">./colorsets/red.xml</include>
   <include subset="MainBGColor" name="Blue" displayName="${hueblue}">./colorsets/blue.xml</include>
   <include subset="MainBGColor" name="Purple" displayName="${huepurple}">./colorsets/purple.xml</include>
   <include subset="shader" name="None" displayName="${none}"/>
   <include subset="shader" name="ScanLines">./effects/scanliness.xml</include>
   <include subset="shader" name="Crt">./effects/crtt.xml</include>
   <include subset="shader" name="Phosphore">./effects/phosphore.xml</include>
   <include subset="shader" name="Scanlines Alternative" displayName="${scanalt}">./effects/scanliness.xml</include>
   <include subset="shader" name="Phosphore +">./effects/phosplus.xml</include>
   <include subset="shader" name="Vertical Scanlines">./effects/scanvert.xml</include>
   <include subset="shader" name="Vertical Fine">./effects/verticalfine.xml</include>
   <include subset="animcarousel" name="Animated Wheel Carousel" displayName="${animcarou}">./effects/animatedcarousel.xml</include>
   <include subset="animcarousel" name="Animated Wheel Carousel 2" displayName="${animwcarou}">./effects/animatedwcarousel.xml</include>
   <include subset="animcarousel" name="Default" displayName="${default}"/>
   <include subset="animbg" name="Animated Background" displayName="${animbg}">./effects/animatedbg2.xml</include>
   <include subset="animbg" name="Animated Background2" displayName="${animbg2}">./effects/animatedbg.xml</include>
   <include subset="animbg" name="Default" displayName="${default}"/>
   <include subset="iconanim" name="yes" displayName="${yes}"/>
   <include subset="iconanim" name="no" displayName="${no}"/> 
   <include subset="syscarousel" name="Wheel" displayName="${wheel}">./effects/carouselwheel.xml</include>
   <include subset="syscarousel" name="Vertical">./effects/carouselvert.xml</include>
   <include subset="syscarousel" name="Without Vertical Carousel" displayName="${snocarou}">./effects/wcarousel.xml</include>
   <!-- CoinOPS system view: loaded AFTER syscarousel so its horizontal carousel wins over the wheel -->
   <include subset="systemview" name="CoinOPS" displayName="CoinOPS">./systemview/coinops.xml</include>
   <!-- Gamelist background: fanart (default) or a plain brick wall. Loaded after coinops-wheel.xml so the override wins. -->
   <include subset="fanartbg" name="Fanart" displayName="Fanart background"/>
   <include subset="fanartbg" name="Brick" displayName="Brick wall (no fanart)">./fanart_off.xml</include>
   <include subset="sysname" name="Text" displayName="${systex}">./colorsets/texttitle.xml</include>
   <include subset="sysname" name="Logo" displayName="${syslog}">./colorsets/logotitle.xml</include>
   <include subset="sysname" name="Without" displayName="${none}">./colorsets/wtitle.xml</include>
   <include subset="randomvid" name="yes" displayName="${yes}"/>
   <include subset="randomvid" name="no" displayName="${no}"/> 
   <include subset="showfrontend" name="automatic" displayName="${yes}">./colorsets/showfrontend.xml</include>
   <include subset="showfrontend" name="forcebatocera" displayName="${forcebatocera}">./colorsets/showfrontendbat.xml</include>
   <include subset="showfrontend" name="no" displayName="${no}"/>   
   <include subset="shader" name="Crt Full Screen" displayName="${scrtfs}">./effects/crt.xml</include>
   <include subset="shader" name="ScanLines Full Screen" displayName="${sclfs}">./effects/scanlines.xml</include>
   <include subset="shader" name="VHS Glitch (Heavy)" displayName="${svhsgl}">./effects/vhs.xml</include>
   <include subset="shader" name="CRT Glitch (Heavy)" displayName="${scrtgl}">./effects/crtvideo.xml</include>
   <include subset="tveffect" name="None" displayName="${none}" appliesTo="HCoinSpin,CoinOps Details"/>
   <include subset="tveffect" name="ScanLines" appliesTo="HCoinSpin,CoinOps Details">./effects/scanlinescoin.xml</include>
   <include subset="tveffect" name="Phosphore" appliesTo="HCoinSpin,CoinOps Details">./effects/phosphorecoin.xml</include>
   <include subset="tveffect" name="Phosphore +" appliesTo="HCoinSpin,CoinOps Details">./effects/phospluscoin.xml</include>
   <include subset="tveffect" name="ScanAlt" appliesTo="HCoinSpin,CoinOps Details" displayName="${scanalt}">./effects/scanlinesscoin.xml</include>
   <include subset="tveffect" name="Vertical Scanlines" appliesTo="HCoinSpin,CoinOps Details">./effects/scanvertcoin.xml</include>
   <include subset="tveffect" name="Vertical Fine" appliesTo="HCoinSpin,CoinOps Details">./effects/verticalfinecoin.xml</include>
   <include subset="tveffect" name="Glitch (Video)" appliesTo="HCoinSpin,CoinOps Details">./effects/vhscoin.xml</include>
   <include subset="tveffect" name="CRT (Video)" appliesTo="HCoinSpin,CoinOps Details">./effects/crtcoin.xml</include>
   <include subset="ShowTopMarquee" name="Yes" displayName="${yes}" appliesTo="HCoinSpin,CoinOps Details">./colorsets/wmarquee.xml</include>
   <include subset="ShowTopMarquee" name="No" displayName="${no}" appliesTo="HCoinSpin,CoinOps Details">./colorsets/nmarquee.xml</include>
   <include subset="CoinOpsDefault" name="Default" displayName="${default}" appliesTo="HCoinSpin,CoinOps Details">./colorsets/coinops.xml</include>
   <include subset="CoinOpsDefault" name="TV Only" displayName="${copstv}" appliesTo="HCoinSpin,CoinOps Details">./colorsets/tv.xml</include>
   <include subset="CoinOpsDefault" name="Arcade Only" displayName="${copsarc}" appliesTo="HCoinSpin,CoinOps Details">./colorsets/arcade.xml</include>
   <variables> <subset.MainBGColor>Main Background Color</subset.MainBGColor> <subset.CoinOpsDefault>CoinOps Default System</subset.CoinOpsDefault>
   <subset.tveffect>TV Effect CoinOps View</subset.tveffect> <subset.ShowTopMarquee>Show Top Marquee in CoinOps Views</subset.ShowTopMarquee>
   <subset.syscarousel>System Carousel</subset.syscarousel>  <subset.sysname>System name on System view</subset.sysname>
   <theme.mostplayed>Most Played:</theme.mostplayed>  <GamesNumber>Games</GamesNumber>  <GamesFavs>Favorites</GamesFavs>
   <NumberPlayed>Games Played</NumberPlayed>  <subset.showfrontend>Show Frontend on Cobalto View</subset.showfrontend>
   <forcebatocera>Show only Batocera</forcebatocera>    <subset.randomvid>Random Video</subset.randomvid>
   <subset.animcarousel>Animated Wheel Carousel</subset.animcarousel>  <subset.animbg>Animated Background</subset.animbg> 
   <subset.iconanim>Cobalto View Icons Animation</subset.iconanim>
   </variables>

